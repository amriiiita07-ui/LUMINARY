// ─────────────────────────────────────────────────────────────
// LUMINARY — Prisma Schema
// Urban Intelligence Platform · PostgreSQL
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskTier {
  NOMINAL
  ELEVATED
  CRITICAL
}

enum SignalType {
  MOBILITY
  AIR_QUALITY
  NOISE
  SENTIMENT
  ENERGY
  SAFETY
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

model City {
  id          String   @id @default(cuid())
  name        String   @unique
  country     String
  lat         Float
  lng         Float
  timezone    String   @default("UTC")
  population  Int
  areaKm2     Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  zones       Zone[]
  districts   District[]
  @@index([name])
}

model District {
  id          String   @id @default(cuid())
  name        String
  cityId      String
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  population  Int      @default(0)
  createdAt   DateTime @default(now())
  zones       Zone[]
  @@unique([name, cityId])
  @@index([cityId])
}

model Zone {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  districtId  String
  district    District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  cityId      String
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  lat         Float
  lng         Float
  areaKm2     Float
  population  Int
  zoneType    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mobilityEvents  MobilityEvent[]
  anomalies       Anomaly[]
  sentimentLogs   SentimentLog[]
  airQualityLogs  AirQualityLog[]
  riskSnapshots   RiskSnapshot[]
  @@index([cityId])
  @@index([districtId])
  @@index([code])
}

model MobilityEvent {
  id              String   @id @default(cuid())
  zoneId          String
  zone            Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  mobilityScore   Float
  pedestrianCount Int
  vehicularCount  Int
  transitCount    Int
  cyclistCount    Int      @default(0)
  avgSpeedKmh     Float    @default(0)
  congestionPct   Float    @default(0)
  dataSource      String   @default("gtfs")
  recordedAt      DateTime @default(now())
  @@index([zoneId, recordedAt])
  @@index([recordedAt])
}

model AirQualityLog {
  id          String   @id @default(cuid())
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  aqi         Int
  pm25        Float
  pm10        Float
  no2         Float
  o3          Float
  co          Float
  category    String
  recordedAt  DateTime @default(now())
  @@index([zoneId, recordedAt])
}

model Anomaly {
  id          String     @id @default(cuid())
  zoneId      String
  zone        Zone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  signalType  SignalType
  zScore      Float
  baselineVal Float
  actualVal   Float
  severity    Severity
  resolved    Boolean    @default(false)
  notes       String?
  detectedAt  DateTime   @default(now())
  resolvedAt  DateTime?
  @@index([zoneId, detectedAt])
  @@index([severity, resolved])
}

model SentimentLog {
  id          String   @id @default(cuid())
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  score       Float
  magnitude   Float    @default(0)
  volume      Int
  topic       String
  source      String   @default("public_data")
  recordedAt  DateTime @default(now())
  @@index([zoneId, recordedAt])
}

model RiskSnapshot {
  id              String   @id @default(cuid())
  zoneId          String
  zone            Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  riskScore       Float
  riskTier        RiskTier
  riskRank        Int
  weeklyDriftPct  Float    @default(0)
  anomalyCount    Int      @default(0)
  avgMobility     Float    @default(0)
  snapshotDate    DateTime @default(now())
  @@unique([zoneId, snapshotDate])
  @@index([snapshotDate])
  @@index([riskTier])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(ANALYST)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  savedReports  SavedReport[]
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model SavedReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  queryType   String
  parameters  Json
  createdAt   DateTime @default(now())
  @@index([userId])
}
