// ─────────────────────────────────────────────────────────────
// LUMINARY — Prisma Schema
// Urban Intelligence Platform · PostgreSQL
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskTier {
  NOMINAL
  ELEVATED
  CRITICAL
}

enum SignalType {
  MOBILITY
  AIR_QUALITY
  NOISE
  SENTIMENT
  ENERGY
  SAFETY
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

// ── Core Models ────────────────────────────────────────────

model City {
  id          String   @id @default(cuid())
  name        String   @unique
  country     String
  lat         Float
  lng         Float
  timezone    String   @default("UTC")
  population  Int
  areaKm2     Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zones       Zone[]
  districts   District[]

  @@index([name])
}

model District {
  id          String   @id @default(cuid())
  name        String
  cityId      String
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  population  Int      @default(0)
  createdAt   DateTime @default(now())

  zones       Zone[]

  @@unique([name, cityId])
  @@index([cityId])
}

model Zone {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique          // e.g. "NYC-MH-001"
  districtId  String
  district    District @relation(fields: [districtId], references: [id], onDelete: Cascade)
  cityId      String
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  lat         Float
  lng         Float
  areaKm2     Float
  population  Int
  zoneType    String                    // commercial | residential | mixed | industrial
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mobilityEvents  MobilityEvent[]
  anomalies       Anomaly[]
  sentimentLogs   SentimentLog[]
  airQualityLogs  AirQualityLog[]
  riskSnapshots   RiskSnapshot[]

  @@index([cityId])
  @@index([districtId])
  @@index([code])
}

// ── Mobility Data ──────────────────────────────────────────

model MobilityEvent {
  id              String   @id @default(cuid())
  zoneId          String
  zone            Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  mobilityScore   Float                 // 0–100 composite score
  pedestrianCount Int
  vehicularCount  Int
  transitCount    Int                   // buses, trains, etc.
  cyclistCount    Int      @default(0)
  avgSpeedKmh     Float    @default(0)
  congestionPct   Float    @default(0)  // 0–100

  dataSource      String   @default("gtfs") // gtfs | sensor | model
  recordedAt      DateTime @default(now())

  @@index([zoneId, recordedAt])
  @@index([recordedAt])
}

// ── Air Quality ────────────────────────────────────────────

model AirQualityLog {
  id          String   @id @default(cuid())
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  aqi         Int                       // Air Quality Index
  pm25        Float                     // Fine particulates µg/m³
  pm10        Float
  no2         Float                     // Nitrogen dioxide ppb
  o3          Float                     // Ozone ppb
  co          Float                     // Carbon monoxide ppm
  category    String                    // Good | Moderate | Unhealthy | Hazardous

  recordedAt  DateTime @default(now())

  @@index([zoneId, recordedAt])
}

// ── Anomalies ──────────────────────────────────────────────

model Anomaly {
  id          String     @id @default(cuid())
  zoneId      String
  zone        Zone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  signalType  SignalType
  zScore      Float                     // Statistical Z-score
  baselineVal Float                     // Expected value
  actualVal   Float                     // Observed value
  severity    Severity
  resolved    Boolean    @default(false)
  notes       String?

  detectedAt  DateTime   @default(now())
  resolvedAt  DateTime?

  @@index([zoneId, detectedAt])
  @@index([severity, resolved])
}

// ── Sentiment ──────────────────────────────────────────────

model SentimentLog {
  id          String   @id @default(cuid())
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  score       Float                     // -1.0 (negative) to +1.0 (positive)
  magnitude   Float    @default(0)      // Strength of sentiment
  volume      Int                       // Number of data points
  topic       String                    // safety | transport | events | environment
  source      String   @default("public_data")

  recordedAt  DateTime @default(now())

  @@index([zoneId, recordedAt])
}

// ── Risk Snapshots (Materialized daily) ───────────────────

model RiskSnapshot {
  id              String   @id @default(cuid())
  zoneId          String
  zone            Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  riskScore       Float
  riskTier        RiskTier
  riskRank        Int
  weeklyDriftPct  Float    @default(0)
  anomalyCount    Int      @default(0)
  avgMobility     Float    @default(0)
  snapshotDate    DateTime @default(now())

  @@unique([zoneId, snapshotDate])
  @@index([snapshotDate])
  @@index([riskTier])
}

// ── Users & Auth ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(ANALYST)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  savedReports  SavedReport[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Saved Reports ──────────────────────────────────────────

model SavedReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  queryType   String                    // risk | cohort | mobility | anomaly
  parameters  Json                      // Stored filter/date params
  createdAt   DateTime @default(now())

  @@index([userId])
}
